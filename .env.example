NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY is also supported for older projects.

# Solo servidor (API /api/admin/usuarios): crear credenciales Auth
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Modo demo local sin login (desarrollo)
# NEXT_PUBLIC_USE_DEMO_DATA=true

# Token server-side para la pagina interna de planes:
# /propuesta-interna/planes?token=your-internal-token
INTERNAL_PLANS_TOKEN=your-internal-token
